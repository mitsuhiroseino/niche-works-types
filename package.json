  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "module": "./src/index.ts",
  "scripts": {
    "build": "rimraf ./dist && tsc && tsx ./scripts/generatePublishPackageJson.ts",
    "check": "tsc --noEmit",
